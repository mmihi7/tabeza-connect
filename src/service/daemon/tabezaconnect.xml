	<env name="TABEZA_HTTP_PORT" value="8765"/>
	<env name="NODE_ENV" value="production"/>
	<serviceaccount>
		<domain>MIHI-PC</domain>
		<user>LocalSystem</user>
		<password></password>
	</serviceaccount>
	<workingdirectory>C:\Projects\tabeza-connect</workingdirectory>
</service>