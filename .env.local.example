# Supabase URLs
SUPABASE_PUBLIC_URL=http://localhost:8000
API_EXTERNAL_URL=http://localhost:8000

# Studio
STUDIO_DEFAULT_ORGANIZATION=Tabeza
STUDIO_DEFAULT_PROJECT=Tabeza Local

# Auth
SITE_URL=http://localhost:3003
ADDITIONAL_REDIRECT_URLS=http://localhost:3002,http://localhost:3003
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true

# SMTP (optional - for email testing)
SMTP_ADMIN_EMAIL=admin@tabeza.local
SMTP_HOST=mail
SMTP_PORT=2500
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Tabeza

