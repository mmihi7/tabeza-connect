{
  "name": "@tabeza/escpos-parser",
  "version": "1.0.0",
  "description": "Pure ESC/POS parsing logic extracted from TABEZA Virtual Printer - serverless compatible",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "escpos",
    "parser",
    "receipt",
    "pos",
    "pure-logic",
    "serverless"
  ],
  "dependencies": {
    "@tabeza/receipt-schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "fast-check": "^3.15.0",
    "eslint": "^8.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.test.ts",
      "!src/**/__tests__/**"
    ]
  }
}