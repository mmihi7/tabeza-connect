{
  "appId": "com.tabeza.connect",
  "productName": "TabezaConnect",
  "directories": {
    "output": "dist"
  },
  "files": [
    "src/**/*",
    "assets/**/*",
    "config.json",
    "package.json",
    "!src/**/*.test.js",
    "!src/**/__tests__/**"
  ],
  "asarUnpack": [
    "node_modules/winreg/**/*"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "requestedExecutionLevel": "asInvoker",
    "icon": "assets/icon-green.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "TabezaConnect",
    "installerIcon": "assets/icon-green.ico",
    "uninstallerIcon": "assets/icon-green.ico",
    "installerHeaderIcon": "assets/icon-green.ico",
    "runAfterFinish": false,
    "perMachine": false
  },
  "publish": null
}
