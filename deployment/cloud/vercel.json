{
  "name": "tabeza-cloud-system",
  "version": 2,
  "builds": [
    {
      "src": "apps/customer/package.json",
      "use": "@vercel/next",
      "config": {
        "distDir": ".next"
      }
    },
    {
      "src": "apps/staff/package.json", 
      "use": "@vercel/next",
      "config": {
        "distDir": ".next"
      }
    }
  ],
  "routes": [
    {
      "src": "/customer/(.*)",
      "dest": "/apps/customer/$1"
    },
    {
      "src": "/staff/(.*)",
      "dest": "/apps/staff/$1"
    }
  ],
  "buildCommand": "pnpm install --frozen-lockfile && pnpm run build:packages && pnpm run build",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "outputDirectory": null,
  "git": {
    "deploymentEnabled": {
      "main": true,
      "preview": true
    }
  },
  "functions": {
    "apps/customer/api/**/*.ts": {
      "runtime": "@vercel/node@3.0.0"
    },
    "apps/staff/api/**/*.ts": {
      "runtime": "@vercel/node@3.0.0"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Cloud-System",
          "value": "tabeza-vercel"
        }
      ]
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "TABEZA_DEPLOYMENT_TYPE": "cloud"
  }
}